# ─────────────────────────────────────────────────────────────────────────────
# SmartPlatform — Environment Variables
# Copy to .env.local and fill in your values.
# SAME .env.local serves both SmartETF and SmartSuper (monorepo / single Next.js app).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase — shared project for both sites ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose

# ── Site identity — used to show correct branding per domain ─────────────────
# On smartetf.com.au the middleware sets NEXT_PUBLIC_SITE=smartetf
# On smartsuper.com.au the middleware sets NEXT_PUBLIC_SITE=smartsuper
# For local dev, set whichever you're working on.
NEXT_PUBLIC_SITE=smartetf

# ── Stripe (subscription billing) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in Stripe dashboard
STRIPE_PRICE_SMARTETF_PRO=price_...         # $19/mo
STRIPE_PRICE_SMARTETF_PREMIUM=price_...     # $35/mo
STRIPE_PRICE_SMARTSUPER_PRO=price_...       # $29/mo
STRIPE_PRICE_BUNDLE=price_...               # $49/mo

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SMARTETF_URL=https://smartetf.com.au
NEXT_PUBLIC_SMARTSUPER_URL=https://smartsuper.com.au
NEXT_PUBLIC_APP_URL=http://localhost:3000    # local dev

# ── Optional: Google Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_GA_SMARTETF=G-XXXXXXXXXX
NEXT_PUBLIC_GA_SMARTSUPER=G-YYYYYYYYYY
